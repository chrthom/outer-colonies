{
  "name": "outercolonies-client",
  "version": "3.1.0",
  "description": "Outer Colonies Game Client",
  "scripts": {
    "ng": "ng",
    "s": "npm run start",
    "start": "npm run start:development",
    "sd": "npm run start:development",
    "start:development": "ng serve --configuration development",
    "si": "npm run start:integration",
    "start:integration": "ng serve --configuration integration",
    "bs": "npm run build:staging",
    "build:staging": "ng build --configuration staging",
    "bp": "npm run build:prod",
    "build:prod": "ng build --configuration production",
    "test": "node scripts/test.js",
    "test:watch": "node scripts/test.js --watch",
    "lint": "ng lint",
    "format": "npx prettier . --write",
    "check": "npm run format && npm run lint && npm run test"
  },
  "private": true,
  "author": "Christopher Thomsen",
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "phaser": "^3.0.0",
    "rxjs": "^7.8.2",
    "socket.io-client": "^4.0.0",
    "tslib": "^2.0.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@types/jasmine": "^6.0.0",
    "@types/matter-js": "~0.19.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-prefer-arrow": "~1.2.0",
    "jasmine-core": "^6.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.0.0",
    "karma-coverage": "^2.0.0",
    "karma-jasmine": "^5.0.0",
    "karma-jasmine-html-reporter": "^2.0.0",
    "prettier": "^3.0.0",
    "puppeteer": "^25.0.4",
    "typescript": "~5.9.0"
  }
}
