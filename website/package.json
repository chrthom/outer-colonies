{
  "name": "outercolonies-website",
  "version": "3.0.0",
  "description": "Outer Colonies Website",
  "scripts": {
    "ng": "ng",
    "s": "npm run start",
    "start": "npm run start:development",
    "sd": "npm run start:development",
    "start:development": "ng serve --configuration development",
    "si": "npm run start:integration",
    "start:integration": "ng serve --configuration integration",
    "bs": "npm run build:staging",
    "build:staging": "ng build --configuration staging",
    "bp": "npm run build:prod",
    "build:prod": "ng build --configuration production",
    "test": "ng test --watch=false --code-coverage --browsers=Chromium",
    "test:watch": "ng test --browsers=Chromium",
    "test:verify": "./verify-tests.sh",
    "lint": "ng lint",
    "format": "npx prettier . --write",
    "check": "npm run format; npm run lint; npm run test:verify"
  },
  "private": true,
  "author": "Christopher Thomsen",
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@typescript-eslint/utils": "^8.57.2",
    "lodash-es": "^4.17.23",
    "ngx-cookie-service": "^20.1.1",
    "rxjs": "~7.8.2",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.21",
    "@angular-eslint/builder": "^19.8.1",
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular-eslint/eslint-plugin-template": "^19.8.1",
    "@angular-eslint/schematics": "^19.8.1",
    "@angular-eslint/template-parser": "^19.8.1",
    "@angular/cli": "^19.2.22",
    "@angular/compiler-cli": "^20.3.18",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/jasmine": "^6.0.0",
    "@types/lodash-es": "^4.17.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-plugin-prefer-arrow": "~1.2.0",
    "jasmine-core": "^6.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.1",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "typescript": "^5.9.3"
  }
}
