{
  "name": "outercolonies-website",
  "version": "3.0.0",
  "description": "Outer Colonies Website",
  "scripts": {
    "ng": "ng",
    "s": "npm run start",
    "start": "npm run start:development",
    "sd": "npm run start:development",
    "start:development": "ng serve --configuration development",
    "si": "npm run start:integration",
    "start:integration": "ng serve --configuration integration",
    "bs": "npm run build:staging",
    "build:staging": "ng build --configuration staging",
    "bp": "npm run build:prod",
    "build:prod": "ng build --configuration production",
    "test": "node scripts/test.js",
    "test:watch": "node scripts/test.js --watch",
    "lint": "ng lint",
    "format": "npx prettier . --write",
    "check": "npm run format && npm run lint && npm run test"
  },
  "private": true,
  "author": "Christopher Thomsen",
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@typescript-eslint/utils": "^8.0.0",
    "lodash-es": "^4.0.0",
    "ngx-cookie-service": "^20.0.0",
    "rxjs": "~7.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@types/jasmine": "^6.0.0",
    "@types/lodash-es": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-prefer-arrow": "~1.2.0",
    "jasmine-core": "^6.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.0.0",
    "karma": "^6.0.0",
    "karma-chrome-launcher": "^3.0.0",
    "karma-coverage": "^2.0.0",
    "karma-firefox-launcher": "^2.0.0",
    "karma-jasmine": "^5.0.0",
    "karma-jasmine-html-reporter": "^2.0.0",
    "prettier": "^3.0.0",
    "puppeteer": "^24.40.0",
    "typescript": "^5.7.3"
  }
}
